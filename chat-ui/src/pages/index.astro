---
import '../styles/chat.css';
import { demoQuestions } from '../lib/demoQuestions';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Local AI Assistant</title>
  </head>
  <body>
    <main class="chat-workspace">
      <header class="page-header">
        <h1>Local AI Assistant</h1>
        <p>
          Questions and answers stay visible in this browser session. Each request sends only your
          latest question to the Assistant API — not prior turns.
        </p>
      </header>

      <section
        id="message-thread"
        class="message-thread"
        role="log"
        aria-label="Chat Interface session display"
      ></section>

      <p id="status" class="status" hidden></p>

      <section class="demo-chips" aria-label="Demo questions">
        <h2 class="demo-chips-heading">Demo questions</h2>
        <div class="demo-chips-list" role="group" aria-label="Fill composer with a demo question">
          {
            demoQuestions.questions.map((item) => (
              <button
                type="button"
                class="demo-chip"
                data-question={item.question}
                data-chip-key={item.key}
              >
                {item.key}
              </button>
            ))
          }
        </div>
      </section>

      <form id="chat-form" class="chat-form">
        <label for="question">Your question</label>
        <textarea
          id="question"
          name="question"
          rows="3"
          required
          placeholder="What is the capital city of Germany?"
        ></textarea>
        <div class="composer-actions">
          <button type="submit" id="submit-button">Ask</button>
          <button type="button" id="stop-button" class="stop-button" hidden>Stop</button>
        </div>
      </form>
    </main>

    <script>
      import { HttpRequestError, StreamAbortedError, streamQuestion } from '../lib/api';
      import { createChatController } from '../lib/chatController';
      import { createDomAdapter } from '../lib/domAdapter';

      const elements = {
        form: document.getElementById('chat-form') as HTMLFormElement,
        questionInput: document.getElementById('question') as HTMLTextAreaElement,
        submitButton: document.getElementById('submit-button') as HTMLButtonElement,
        stopButton: document.getElementById('stop-button') as HTMLButtonElement,
        status: document.getElementById('status') as HTMLParagraphElement,
        messageThread: document.getElementById('message-thread') as HTMLElement,
      };

      const dom = createDomAdapter(elements);
      dom.bindScrollBehavior();

      const chipButtons = Array.from(
        document.querySelectorAll<HTMLButtonElement>('.demo-chip'),
      );

      const setChipsEnabled = (enabled: boolean): void => {
        chipButtons.forEach((button) => {
          button.disabled = !enabled;
        });
      };

      chipButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const question = button.dataset.question;
          if (!question) {
            return;
          }
          elements.questionInput.value = question;
          elements.questionInput.focus();
        });
      });

      const controller = createChatController({
        onTurnUpdated: () => {
          dom.renderSession(controller.session, controller.activeTurnIndex);
        },
        onValidationError: (message) => {
          dom.showValidationStatus(message);
        },
      });

      const submitQuestion = (): void => {
        elements.form.requestSubmit();
      };

      dom.bindComposerKeys(submitQuestion);

      elements.stopButton.addEventListener('click', () => {
        controller.stopActiveTurn();
        dom.restoreComposer();
      });

      elements.form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const question = elements.questionInput.value.trim();
        if (!question) {
          dom.showValidationStatus('Enter a question before submitting.');
          return;
        }

        const turnIndex = controller.submitQuestion(question);
        elements.questionInput.value = '';
        dom.setComposerEnabled(false);
        setChipsEnabled(false);
        dom.setStopVisible(true);
        elements.status.hidden = true;

        controller.markStreaming(turnIndex);

        try {
          await streamQuestion(
            question,
            {
              onTrace: (payload) => controller.handleTrace(turnIndex, payload),
              onToken: (payload) => controller.handleToken(turnIndex, payload),
              onFinal: (response) => controller.handleFinal(turnIndex, response),
              onStreamError: (payload) => controller.handleStreamError(turnIndex, payload),
              onAbort: () => {
                if (
                  turnIndex === controller.activeTurnIndex &&
                  controller.getTurnStatus(turnIndex) === 'streaming'
                ) {
                  controller.stopActiveTurn();
                }
              },
            },
            controller.getStreamAbortSignal(),
          );
        } catch (error) {
          if (error instanceof StreamAbortedError) {
            return;
          }

          const message = error instanceof Error ? error.message : 'Request failed.';

          if (error instanceof HttpRequestError && error.status === 400) {
            controller.handleValidationError(message, turnIndex);
          } else if (
            controller.getTurnStatus(turnIndex) === 'streaming' ||
            controller.getTurnStatus(turnIndex) === 'pending'
          ) {
            controller.handleConnectionError(turnIndex, message);
          }
        } finally {
          dom.restoreComposer();
          setChipsEnabled(true);
        }
      });
    </script>
  </body>
</html>
