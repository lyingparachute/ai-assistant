# Local secrets for the assistant stack.
# Copy this file to `.env` and fill in your own keys: `cp .env.example .env`
# `.env` is gitignored — never commit real keys. `scripts/start-assistant.sh` sources `.env` on startup.

# WeatherAPI.com — free tier, no card. Get a key at https://www.weatherapi.com/my/
WEATHER_API_KEY=
WEATHER_API_URL=https://api.weatherapi.com/v1/current.json

# REST Countries v5 — free tier (500 req/month). Get a key at https://restcountries.com
REST_COUNTRIES_API_KEY=
